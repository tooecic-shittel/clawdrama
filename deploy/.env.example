# 复制为同目录 .env 并填好（真 .env 只放服务器，切勿提交 git）。
# 这些 key 走环境变量注入，绝不写进代码/镜像。

# === 安全（必填）===
# 设一个长随机串：openssl rand -hex 32
# 想让 Railway 上已登录用户迁移后无需重登，就填和 Railway 上一样的值
JWT_SECRET=

# === AI 服务 key ===
ARK_API_KEY=          # 火山方舟 Seedance（视频主力；火山云上同厂内网更快）
MINIMAX_API_KEY=      # MiniMax 配音
YUNWU_API_KEY=        # 云雾（happyhorse 兜底视频；图片若走云雾也用它）
# ⚠ 大陆机房连不上 Google，下面两个留空，并把文本模型改成国产（见 README「去 Google 化」）
GOOGLE_API_KEY=       # Gemini 文本（大陆不可用 → 留空）
GOOGLE_VIDEO_API_KEY= # Veo 兜底（大陆不可用 → 留空）

# === 支付宝支付（可选，启用用户自助充值/订阅）===
# APP_ID 在支付宝开放平台应用详情页，形如 202100xxxxxxxxxx
ALIPAY_APP_ID=
# 应用私钥：只放服务器 .env，不提交。支持单行 base64 或 PEM 格式。
ALIPAY_PRIVATE_KEY=
# 支付宝公钥：不是“应用公钥”，是在开放平台完成接口加签后展示/下载的支付宝公钥。
ALIPAY_PUBLIC_KEY=
PUBLIC_BASE_URL=https://clawdrama.claw-pi.cn
# 默认值通常不用改：
# ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
# ALIPAY_NOTIFY_URL=https://clawdrama.claw-pi.cn/api/v1/payments/alipay/notify
# ALIPAY_RETURN_URL=https://clawdrama.claw-pi.cn/credits?payment=success

# === 调优（可选）===
SEEDANCE_CONCURRENCY=4
SEEDANCE_QUEUE_WAIT_MS=600000

# === 仅当改用「CI 构建 + 镜像仓库 pull」才需要（服务器本机构建时不用填）===
# IMAGE=cr.volces.com/你的命名空间/clawdrama:latest

# === 学习中心（电商学习卡兑换） ===
# 兑换码 HMAC 密钥：至少 32 字节随机值（openssl rand -hex 32）。
# 只放生产环境，绝不提交 Git；有用户兑换后不可再更换。
REDEMPTION_CODE_PEPPER=
# 每张学习卡默认随课积分（创建批次时可调整）
LEARNING_CARD_DEFAULT_CREDITS=30000
# 微信群与直播入口，留空则前端隐藏对应按钮
LEARNING_WECHAT_URL=
LEARNING_LIVE_URL=
