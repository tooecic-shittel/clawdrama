# 复制为同目录 .env 并填好（真 .env 只放服务器，切勿提交 git）。
# 这些 key 走环境变量注入，绝不写进代码/镜像。

# === 安全（必填）===
# 设一个长随机串：openssl rand -hex 32
# 想让 Railway 上已登录用户迁移后无需重登，就填和 Railway 上一样的值
JWT_SECRET=

# === AI 服务 key ===
ARK_API_KEY=          # 火山方舟 Seedance（视频主力；火山云上同厂内网更快）
MINIMAX_API_KEY=      # MiniMax 配音
YUNWU_API_KEY=        # 云雾（happyhorse 兜底视频；图片若走云雾也用它）
# ⚠ 大陆机房连不上 Google，下面两个留空，并把文本模型改成国产（见 README「去 Google 化」）
GOOGLE_API_KEY=       # Gemini 文本（大陆不可用 → 留空）
GOOGLE_VIDEO_API_KEY= # Veo 兜底（大陆不可用 → 留空）

# === 调优（可选）===
SEEDANCE_CONCURRENCY=4
SEEDANCE_QUEUE_WAIT_MS=600000

# === 仅当改用「CI 构建 + 镜像仓库 pull」才需要（服务器本机构建时不用填）===
# IMAGE=cr.volces.com/你的命名空间/clawdrama:latest
